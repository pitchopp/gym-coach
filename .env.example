# --- Claude (auth par OAuth abonnement, pas de clé API) ---
MODEL=claude-sonnet-4-6
OAUTH_CREDS_PATH=/data/claude_oauth.json
# Seed initial des credentials OAuth (contenu JSON du Keychain "Claude Code-credentials").
# Utilisé une seule fois si le fichier OAUTH_CREDS_PATH n'existe pas encore.
CLAUDE_OAUTH_JSON={"claudeAiOauth":{"accessToken":"...","refreshToken":"...","expiresAt":0}}

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-...        # créé via @BotFather
WEBHOOK_SECRET=change-me-long-random      # segment d'URL secret du webhook

# --- Service ---
PUBLIC_URL=https://coach.exemple.com      # domaine public (Dokploy/Traefik)
DB_PATH=./data/coach.db                    # en prod: /data/coach.db (volume persistant)
TICK_MINUTES=15                            # période d'évaluation de la proactivité
DEFAULT_TZ=Europe/Paris
CHECKIN_GRACE_MINUTES=45                    # délai après le créneau avant la relance de séance
ONBOARDING_IDLE_HOURS=20                    # silence minimal avant une relance d'onboarding
ONBOARDING_MAX_NUDGES=3                     # nb max de relances d'onboarding sans réponse

# --- Déploiement (déjà présent) ---
# DOKPLOY_API_KEY=...
# LINEAR_API_KEY=...
